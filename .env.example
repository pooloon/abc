# Open DART API Key (https://opendart.fss.or.kr/)
# 로컬 빌드 캐시: DART_API_KEY=xxx npm run build:dart-cache
# GitHub Actions: Settings → Secrets → DART_API_KEY (클라이언트에 노출되지 않음)
DART_API_KEY=

# 로컬 dev 편의 (선택 — 브라우저 번들에 포함됨)
VITE_DART_API_KEY=

# OpenAI GPT (선택 — index.html __NE_CONFIG__ 또는 앱 재무·설정 탭에서도 입력 가능)
VITE_OPENAI_API_KEY=
