{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/yahoo/(.*)",
      "destination": "https://query1.finance.yahoo.com/$1"
    },
    {
      "source": "/api/dart/(.*)",
      "destination": "https://opendart.fss.or.kr/api/$1"
    },
    {
      "source": "/api/krx/(.*)",
      "destination": "https://data.krx.co.kr/$1"
    }
  ]
}
